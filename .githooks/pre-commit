#!/usr/bin/env bash
set -euo pipefail

if ! command -v gitleaks &>/dev/null; then
  echo "WARNING: gitleaks not installed. Install: brew install gitleaks"
  exit 0
fi

echo "Running gitleaks pre-commit scan..."
if ! gitleaks git --pre-commit --staged --verbose --config="$(git rev-parse --show-toplevel)/.gitleaks.toml" 2>&1; then
  echo ""
  echo "============================================"
  echo "  COMMIT BLOCKED: Secrets detected!"
  echo "  Review findings above."
  echo "  False positive? Add to .gitleaks.toml allowlist."
  echo "============================================"
  exit 1
fi

echo "gitleaks: clean."
