# AI Service Configuration
AI_SERVICE_PORT=8082
HEALTH_CHECK_PORT=8081

# Qwen3-Omni Configuration
# 获取 DashScope API Key:
# 1. 访问阿里云官网并登录
# 2. 进入 DashScope 控制台 (https://dashscope.console.aliyun.com/)
# 3. 创建或获取现有的 API Key
# 4. 将 API Key 填入下方变量
QWEN3_OMNI_API_KEY=sk-xxxxxx

# Qwen3-Omni 模型名称，根据 DashScope 控制台中的实际模型名称进行调整
# 实时模型名称
QWEN3_OMNI_MODEL=qwen3.5-omni-plus-realtime

# Model Configuration (用于模拟模式)
ASR_MODEL=Xenova/whisper-tiny.en
TTS_MODEL=Xenova/speecht5_tts
LLM_MODEL=qwen3-omni

# 每日对话轮次上限（成本护栏）— 免费/付费每日 AI 语音回复轮次上限
# 用完硬拦并引导订阅。不设则用代码默认值（15 / 150）。
FREE_DAILY_TURNS=15
PRO_DAILY_TURNS=150

# Feature Flags
# 设置为 false 以启用真实 API 模式
ENABLE_MOCK_MODE=false
ENABLE_STREAMING=true
ENABLE_WEBSOCKET=true

# Logging
LOG_LEVEL=info
NODE_ENV=development

# CORS — comma-separated list of allowed origins (must match Nginx api-gateway allowlist)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001,https://guajiguaji.top,https://www.guajiguaji.top