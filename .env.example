# Environment Configuration Template
# Copy this file to .env and update with your actual values

# Application Environment
NODE_ENV=development
PORT=8080

# JWT Configuration - Generate strong random keys (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-a-random-string-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-to-a-different-random-string-at-least-32-characters-long

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/oral_app
DATABASE_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/oral_app

# Service URLs (for Docker/local development)
USER_SERVICE_URL=http://localhost:3001
AI_SERVICE_URL=http://localhost:8082
COMMS_SERVICE_URL=http://localhost:3003
CONVERSATION_SERVICE_URL=http://localhost:8000
HISTORY_ANALYTICS_SERVICE_URL=http://localhost:8001
MEDIA_PROCESSING_SERVICE_URL=http://localhost:8002

# AI Service Configuration
AI_INTEGRATIONS_OPENROUTER_API_KEY=your-openrouter-api-key
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-openai-api-key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001,http://localhost:3001

# Security Configuration
JWT_SECRET_MIN_LENGTH=32
ENCRYPTION_KEY=your-encryption-key-32-characters-long

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_MAX_AUTH_ATTEMPTS=5

# Logging
LOG_LEVEL=info
SECURITY_LOG_ENABLED=true