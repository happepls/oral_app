# Security Configuration for Oral AI Application
# Copy this file to .env and update with your actual values

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-token-secret-minimum-32-characters-long

# API Keys (generate secure random strings)
AI_INTEGRATIONS_OPENROUTER_API_KEY=your-openrouter-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_CLIENT_ID=your-google-client-id
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Database Security
DATABASE_URL=postgresql://username:password@localhost:5432/oral_app
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Redis Security
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# MongoDB Security
MONGODB_URI=mongodb://username:password@localhost:27017/oral_app
MONGODB_SSL=true

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001,https://localhost:3000,https://localhost:5001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_MAX_AUTH_ATTEMPTS=5

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# IP Filtering (optional)
ALLOWED_IPS=
BLOCKED_IPS=

# Request Size Limits
MAX_REQUEST_SIZE=10mb
MAX_FILE_UPLOAD_SIZE=50mb

# Session Configuration
SESSION_SECRET=your-session-secret-minimum-32-characters
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
SESSION_MAX_AGE=86400000

# Logging
LOG_LEVEL=info
LOG_SENSITIVE_DATA=false
SECURITY_LOG_ENABLED=true

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-characters-long
ENCRYPTION_ALGORITHM=aes-256-gcm

# Two-Factor Authentication
TOTP_SERVICE_NAME=Oral AI
TOTP_ISSUER=Oral AI Platform

# API Security
API_KEY_LENGTH=32
API_KEY_PREFIX=oral_
API_RATE_LIMIT=5000

# WebSocket Security
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS_PER_IP=10
WS_MESSAGE_SIZE_LIMIT=1mb

# Audio Streaming Security
AUDIO_SAMPLE_RATE_INPUT=16000
AUDIO_SAMPLE_RATE_OUTPUT=24000
AUDIO_MAX_DURATION=300000
AUDIO_ALLOWED_FORMATS=wav,mp3,opus

# File Upload Security
ALLOWED_FILE_TYPES=audio/wav,audio/mp3,audio/opus
MAX_FILE_SIZE=52428800
SCAN_UPLOADS_FOR_MALWARE=true

# Email Security
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_EXPIRY=86400000
PASSWORD_RESET_EXPIRY=3600000

# Account Security
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900000
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_HISTORY_COUNT=5

# Privacy
DATA_RETENTION_DAYS=365
ANONYMIZE_USER_DATA=true
DELETE_INACTIVE_USERS_AFTER=730

# Monitoring
SECURITY_ALERTS_ENABLED=true
SECURITY_ALERT_EMAIL=security@oralapp.com
BREACH_DETECTION_ENABLED=true
ANOMALY_DETECTION_ENABLED=true